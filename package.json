{
  "name": "stereocord",
  "version": "1.0.0",
  "description": "Cliente modificado de Discord con soporte de plugins y temas",
  "main": "install.js",
  "scripts": {
    "install-sc":   "node install.js",
    "uninstall-sc": "node uninstall.js",
    "build:win":    "pkg install.js --targets node22-win-x64   --output dist/StereoCord-installer-win.exe   --compress GZip",
    "build:linux":  "pkg install.js --targets node22-linux-x64 --output dist/StereoCord-installer-linux     --compress GZip",
    "build:mac":    "pkg install.js --targets node22-macos-x64 --output dist/StereoCord-installer-mac       --compress GZip",
    "build:all":    "npm run build:win && npm run build:linux && npm run build:mac"
  },
  "author": "complementacion",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/complementacion/stereocord.git"
  },
  "homepage": "https://github.com/complementacion/stereocord#readme",
  "bugs": {
    "url": "https://github.com/complementacion/stereocord/issues"
  },
  "dependencies": {
    "asar": "^3.2.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.0"
  },
  "pkg": {
    "assets": [
      "src/**/*",
      "data/**/*"
    ],
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "dist"
  }
}
